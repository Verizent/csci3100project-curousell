<div class="max-w-lg mx-auto mt-16 p-8 bg-white rounded-lg shadow text-center">
  <h1 class="text-2xl font-bold text-green-600 mb-4">Payment Successful!</h1>
  <p class="text-gray-700 mb-2">Your order for <strong><%= @order.product.title %></strong> has been placed.</p>
  <p class="text-gray-500 mb-6">Amount: <%= number_to_currency(@order.amount, unit: "HK$") %></p>
  <p class="text-sm text-gray-400">Order #<%= @order.id %></p>
  <%= link_to "Back to Home", root_path, class: "mt-6 inline-block px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700" %>
</div>
