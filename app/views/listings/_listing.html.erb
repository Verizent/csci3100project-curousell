<%
  status_classes = {
    "unsold"     => "bg-green-100 text-green-700 border border-green-200",
    "in_process" => "bg-amber-100 text-amber-700 border border-amber-200",
    "sold"       => "bg-gray-100 text-gray-500 border border-gray-200"
  }
  status_labels = {
    "unsold"     => "Available",
    "in_process" => "In Process",
    "sold"       => "Sold"
  }
  category_icons = {
    "furniture"     => "🪑",
    "accessories"   => "👜",
    "tech"          => "💻",
    "books"         => "📚",
    "clothing"      => "👕",
    "miscellaneous" => "📦"
  }
%>
<%= link_to listing_path(listing), class: "block group" do %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100
              hover:shadow-md hover:border-cuhk-gold transition-all duration-200
              overflow-hidden flex flex-col h-full">

    <%# Image %>
    <div class="relative bg-gray-50 aspect-square overflow-hidden">
      <% if listing.images.attached? %>
        <%= image_tag listing.images.first.variant(resize_to_fill: [320, 320]),
              class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300",
              alt: listing.title %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center text-5xl">
          <%= category_icons[listing.category] || "📦" %>
        </div>
      <% end %>

      <%# Status badge %>
      <span class="absolute top-2 right-2 text-xs font-semibold px-2 py-0.5 rounded-full
                   <%= status_classes[listing.status] %>">
        <%= status_labels[listing.status] %>
      </span>

      <%# Restricted badge %>
      <% if listing.restricted? %>
        <span class="absolute top-2 left-2 text-xs font-semibold px-2 py-0.5 rounded-full
                     bg-cuhk-purple text-cuhk-gold border border-cuhk-gold">
          Members Only
        </span>
      <% end %>
    </div>

    <%# Card body %>
    <div class="p-4 flex flex-col flex-1">
      <div class="flex items-center gap-1.5 mb-2">
        <span class="text-xs font-medium text-cuhk-purple border border-cuhk-purple-light
                     rounded-full px-2 py-0.5 capitalize">
          <%= listing.category %>
        </span>
      </div>

      <h3 class="text-gray-800 font-semibold text-sm leading-snug mb-1 line-clamp-2 flex-1">
        <%= listing.title %>
      </h3>

      <% if listing.price.zero? %>
        <p class="text-green-600 font-bold text-lg mt-1">Free</p>
      <% else %>
        <p class="text-cuhk-gold font-bold text-lg mt-1">
          HK$<%= number_with_precision(listing.price, precision: 0, delimiter: ",") %>
        </p>
      <% end %>

      <div class="flex items-center justify-between mt-2 text-xs text-gray-400">
        <span class="flex items-center gap-1 truncate">
          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="truncate"><%= listing.location.presence || "CUHK" %></span>
        </span>
        <span class="flex-shrink-0 ml-2"><%= time_ago_in_words(listing.created_at) %> ago</span>
      </div>

      <div class="flex items-center gap-2 mt-3 pt-3 border-t border-gray-100">
        <div class="w-6 h-6 rounded-full bg-cuhk-purple-light flex items-center justify-center
                    text-white text-xs font-bold flex-shrink-0">
          <%= listing.user.name&.first&.upcase || "?" %>
        </div>
        <span class="text-xs text-gray-500 truncate"><%= listing.user.name %></span>
      </div>
    </div>

  </div>
<% end %>
