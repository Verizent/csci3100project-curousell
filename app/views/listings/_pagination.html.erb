<%
  current      = listings.current_page
  total        = listings.total_pages
  btn_base     = "inline-flex items-center justify-center w-9 h-9 rounded-lg text-sm font-medium transition-colors"
  btn_active   = "#{btn_base} bg-cuhk-purple text-white shadow-sm"
  btn_normal   = "#{btn_base} bg-white text-cuhk-purple border border-gray-200 hover:bg-cuhk-gold hover:text-cuhk-purple hover:border-cuhk-gold"
  btn_disabled = "#{btn_base} bg-gray-50 text-gray-300 border border-gray-100 cursor-not-allowed"

  page_path = ->(page) {
    f = (filters || {}).except(:categories)
    cats = Array((filters || {})[:categories])
    # Rails will serialize categories[] correctly when passed as an array key
    listings_path({ page: page, q: query.presence, "categories[]": cats.presence }.merge(f).compact)
  }
%>

<div class="flex flex-wrap items-center justify-center gap-1.5">

  <%# First page %>
  <% if listings.first_page? %>
    <span class="<%= btn_disabled %>">&laquo;</span>
  <% else %>
    <%= link_to page_path.call(1), class: btn_normal, data: { turbo_frame: "listings_frame" } do %>&laquo;<% end %>
  <% end %>

  <%# Previous page %>
  <% if listings.first_page? %>
    <span class="<%= btn_disabled %>">&lsaquo;</span>
  <% else %>
    <%= link_to page_path.call(current - 1), class: btn_normal, data: { turbo_frame: "listings_frame" } do %>&lsaquo;<% end %>
  <% end %>

  <%
    window      = 2
    first_shown = [ current - window, 1 ].max
    last_shown  = [ current + window, total ].min
  %>

  <% if first_shown > 1 %>
    <%= link_to page_path.call(1), class: btn_normal, data: { turbo_frame: "listings_frame" } do %>1<% end %>
    <% if first_shown > 2 %>
      <span class="<%= btn_disabled %>">…</span>
    <% end %>
  <% end %>

  <% (first_shown..last_shown).each do |page| %>
    <% if page == current %>
      <span class="<%= btn_active %>"><%= page %></span>
    <% else %>
      <%= link_to page_path.call(page), class: btn_normal, data: { turbo_frame: "listings_frame" } do %><%= page %><% end %>
    <% end %>
  <% end %>

  <% if last_shown < total %>
    <% if last_shown < total - 1 %>
      <span class="<%= btn_disabled %>">…</span>
    <% end %>
    <%= link_to page_path.call(total), class: btn_normal, data: { turbo_frame: "listings_frame" } do %><%= total %><% end %>
  <% end %>

  <%# Next page %>
  <% if listings.last_page? %>
    <span class="<%= btn_disabled %>">&rsaquo;</span>
  <% else %>
    <%= link_to page_path.call(current + 1), class: btn_normal, data: { turbo_frame: "listings_frame" } do %>&rsaquo;<% end %>
  <% end %>

  <%# Last page %>
  <% if listings.last_page? %>
    <span class="<%= btn_disabled %>">&raquo;</span>
  <% else %>
    <%= link_to page_path.call(total), class: btn_normal, data: { turbo_frame: "listings_frame" } do %>&raquo;<% end %>
  <% end %>

</div>

<p class="text-center text-gray-400 text-xs mt-3">
  Page <%= current %> of <%= total %>
  &mdash; <%= listings.total_count %> listing<%= listings.total_count == 1 ? "" : "s" %> total
</p>
