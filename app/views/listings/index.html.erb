<% content_for :title, "CUrousell \u2014 Home" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# ── Search + Filter ── %>
  <div data-controller="filters" class="mb-4">

    <%# Search row %>
    <div class="flex items-center gap-2">
      <%= form_with url: listings_path, method: :get, data: { turbo_frame: "_top" }, class: "flex-1" do |f| %>
        <%= f.hidden_field :filter, value: @filter.presence %>
        <div class="flex items-center gap-2 bg-white rounded-2xl shadow-sm border border-cuhk-gold-light/60 px-4 py-2.5 focus-within:border-cuhk-gold focus-within:ring-2 focus-within:ring-cuhk-gold/20 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cuhk-purple/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <%= f.search_field :q,
                value: @query,
                placeholder: "Search listings…",
                autocomplete: "off",
                class: "flex-1 bg-transparent text-cuhk-text placeholder-cuhk-text/30 text-sm focus:outline-none" %>
          <% if @query.present? %>
            <%= link_to listings_path(filter: @filter.presence), class: "text-cuhk-text/30 hover:text-cuhk-purple transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# Filter toggle button %>
      <button type="button"
              data-action="filters#toggle"
              data-filters-target="icon"
              class="shrink-0 p-2.5 rounded-2xl bg-white shadow-sm border border-cuhk-gold-light/60 text-white/60 hover:text-cuhk-gold transition-colors <%= @filter.present? ? 'text-cuhk-gold border-cuhk-gold' : 'text-cuhk-purple/50' %>"
              title="Filter listings">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" />
        </svg>
      </button>
    </div>

    <%# Filter bubbles panel (hidden by default) %>
    <div data-filters-target="panel" class="<%= @filter.present? ? '' : 'hidden' %> mt-3 overflow-x-auto pb-1">
      <div class="flex items-center gap-2 w-max">
        <% filters = [
          ["Free",        "free"],
          ["College",     "college"],
          ["Tech",        "tech"],
          ["Furniture",   "furniture"],
          ["Books",       "books"],
          ["Accessories", "accessories"],
          ["Misc",        "misc"],
          ["Under $50",   "under50"],
          ["Under $100",  "under100"],
          ["New Arrival", "new"]
        ] %>
        <% filters.each do |label, key| %>
          <% active = @filter == key %>
          <% dest = active ? listings_path(q: @query.presence) : listings_path(q: @query.presence, filter: key) %>
          <%= link_to dest,
                class: "px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap border transition-colors
                        #{active ? 'bg-cuhk-purple text-white border-cuhk-purple shadow-sm' : 'bg-white text-cuhk-text border-cuhk-gold-light hover:border-cuhk-purple hover:text-cuhk-purple'}" do %>
            <%= label %>
          <% end %>
        <% end %>
      </div>
    </div>

  </div>

  <%# Active filter / search label %>
  <% if @query.present? || @filter.present? %>
    <p class="mb-4 text-sm text-cuhk-text/50">
      <%= @listings.total_count %> result<%= @listings.total_count == 1 ? "" : "s" %>
      <% if @query.present? %>
        for <span class="font-semibold text-cuhk-purple">"<%= @query %>"</span>
      <% end %>
      <% if @filter.present? %>
        <span class="ml-1 px-2 py-0.5 rounded-full bg-cuhk-purple/10 text-cuhk-purple text-xs font-medium"><%= @filter %></span>
      <% end %>
    </p>
  <% end %>

  <%# ── Listings grid ── %>
  <% if @listings.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      <%= render @listings %>
    </div>

    <%# ── Pagination ── %>
    <% if @listings.total_pages > 1 %>
      <nav class="mt-10 flex items-center justify-center gap-1.5 flex-wrap" aria-label="Pagination">

        <%# First %>
        <% unless @listings.first_page? %>
          <%= link_to "First", listings_path(page: 1, q: @query.presence),
                class: "px-3 py-1.5 rounded-lg text-sm font-medium bg-white border border-cuhk-gold-light text-cuhk-purple hover:bg-cuhk-purple hover:text-white transition-colors" %>
        <% end %>

        <%# Prev %>
        <% unless @listings.first_page? %>
          <%= link_to "← Prev", listings_path(page: @listings.prev_page, q: @query.presence),
                class: "px-3 py-1.5 rounded-lg text-sm font-medium bg-white border border-cuhk-gold-light text-cuhk-purple hover:bg-cuhk-purple hover:text-white transition-colors" %>
        <% end %>

        <%# Page numbers %>
        <% pages = (1..@listings.total_pages).to_a %>
        <% current = @listings.current_page %>
        <% visible = pages.select { |p| p == 1 || p == @listings.total_pages || (p - current).abs <= 2 } %>

        <% prev_p = nil %>
        <% visible.each do |p| %>
          <% if prev_p && p - prev_p > 1 %>
            <span class="px-2 text-cuhk-text/40 text-sm">…</span>
          <% end %>
          <% if p == current %>
            <span class="px-3 py-1.5 rounded-lg text-sm font-bold bg-cuhk-purple text-white shadow-sm"><%= p %></span>
          <% else %>
            <%= link_to p, listings_path(page: p, q: @query.presence),
                  class: "px-3 py-1.5 rounded-lg text-sm font-medium bg-white border border-cuhk-gold-light text-cuhk-purple hover:bg-cuhk-purple hover:text-white transition-colors" %>
          <% end %>
          <% prev_p = p %>
        <% end %>

        <%# Next %>
        <% unless @listings.last_page? %>
          <%= link_to "Next →", listings_path(page: @listings.next_page, q: @query.presence),
                class: "px-3 py-1.5 rounded-lg text-sm font-medium bg-white border border-cuhk-gold-light text-cuhk-purple hover:bg-cuhk-purple hover:text-white transition-colors" %>
        <% end %>

        <%# Last %>
        <% unless @listings.last_page? %>
          <%= link_to "Last", listings_path(page: @listings.total_pages, q: @query.presence),
                class: "px-3 py-1.5 rounded-lg text-sm font-medium bg-white border border-cuhk-gold-light text-cuhk-purple hover:bg-cuhk-purple hover:text-white transition-colors" %>
        <% end %>

      </nav>
    <% end %>

  <% else %>
    <div class="flex flex-col items-center justify-center py-32 text-center">
      <div class="w-20 h-20 rounded-full bg-cuhk-purple/10 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-cuhk-purple/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold text-cuhk-text/60">No listings yet</h2>
      <p class="text-cuhk-text/40 mt-1 text-sm">Be the first to post something!</p>
    </div>
  <% end %>

</div>
