<% content_for :title, "CUrousell — New Listing" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <%= link_to home_path,
        class: "inline-flex items-center gap-1.5 text-cuhk-purple hover:text-cuhk-purple-light
                text-sm font-medium mb-6 group" do %>
    <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none"
         stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to listings
  <% end %>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-8">Post a New Listing</h1>

    <%# Validation errors %>
    <% if @listing.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-6">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-red-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-.75-4.75a.75.75 0 001.5 0V9.25a.75.75 0 00-1.5 0v4zm.75-7.5a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
          </svg>
          <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
            <% @listing.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <%= form_with model: @listing, multipart: true, class: "space-y-6" do |form| %>

      <%# Title %>
      <div>
        <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :title,
              placeholder: "e.g. Calculus textbook, IKEA desk lamp…",
              class: "block w-full px-4 py-3 border border-gray-300 rounded-lg text-sm
                      text-gray-900 placeholder-gray-400
                      focus:outline-none focus:ring-2 focus:ring-cuhk-purple focus:border-cuhk-purple" %>
      </div>

      <%# Description %>
      <div>
        <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :description,
              rows: 4,
              placeholder: "Describe the condition, any defects, reason for selling…",
              class: "block w-full px-4 py-3 border border-gray-300 rounded-lg text-sm
                      text-gray-900 placeholder-gray-400 resize-none
                      focus:outline-none focus:ring-2 focus:ring-cuhk-purple focus:border-cuhk-purple" %>
      </div>

      <%# Price + Category %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= form.label :price, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-400 text-sm pointer-events-none">HK$</span>
            <%= form.number_field :price,
                  min: 0, step: 1,
                  placeholder: "0",
                  class: "block w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg text-sm
                          text-gray-900 placeholder-gray-400
                          focus:outline-none focus:ring-2 focus:ring-cuhk-purple focus:border-cuhk-purple" %>
          </div>
          <p class="mt-1 text-xs text-gray-400">Enter 0 for a free item</p>
          <label class="flex items-center gap-2 mt-2 text-sm text-gray-600 cursor-pointer">
            <%= form.check_box :negotiable, class: "rounded border-gray-300 text-cuhk-purple focus:ring-cuhk-purple" %>
            Price is negotiable
          </label>
        </div>

        <div>
          <%= form.label :category, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.select :category,
                Listing::CATEGORIES.map { |c| [c.capitalize, c] },
                { include_blank: "Select a category" },
                class: "block w-full px-4 py-3 border border-gray-300 rounded-lg text-sm
                        text-gray-900
                        focus:outline-none focus:ring-2 focus:ring-cuhk-purple focus:border-cuhk-purple" %>
        </div>
      </div>

      <%# Location %>
      <div>
        <%= form.label :location, "Meeting Place", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :location,
              placeholder: "e.g. CUHK Library, Chung Chi MTR station…",
              class: "block w-full px-4 py-3 border border-gray-300 rounded-lg text-sm
                      text-gray-900 placeholder-gray-400
                      focus:outline-none focus:ring-2 focus:ring-cuhk-purple focus:border-cuhk-purple" %>
      </div>

      <%# Image %>
      <div>
        <%= form.label :image, "Photo", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.file_field :image,
              accept: "image/*",
              class: "block w-full text-sm text-gray-500
                      file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0
                      file:text-sm file:font-medium
                      file:bg-cuhk-purple file:text-white
                      hover:file:bg-cuhk-purple-dark file:cursor-pointer" %>
        <p class="mt-1 text-xs text-gray-400">Optional — JPEG, PNG or WebP, up to 10 MB</p>
      </div>

      <%# Audience / Access Rules %>
      <div class="border border-gray-200 rounded-xl p-5 space-y-5"
           data-controller="listing-form">
        <div>
          <p class="text-sm font-semibold text-gray-700">Restrict Audience <span class="font-normal text-gray-400">(optional)</span></p>
          <p class="text-xs text-gray-400 mt-0.5">Leave everything unchecked to make this listing visible to all CUHK members. Selecting a faculty with no departments means all departments under it can access.</p>
        </div>

        <%= form.fields_for :access_rules do |ff| %>

          <%# Colleges %>
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Colleges</p>
            <div class="grid grid-cols-2 gap-y-1.5 gap-x-4">
              <% Listing::COLLEGES.each do |college| %>
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <%= ff.check_box :colleges, { multiple: true, checked: Array(ff.object.colleges).include?(college) }, college, nil %>
                  <%= college %>
                </label>
              <% end %>
            </div>
          </div>

          <%# Faculties + Departments (departments revealed per faculty) %>
          <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Faculties</p>
            <div class="space-y-3">
              <% Listing::FACULTY_DEPARTMENTS.each do |faculty, departments| %>
                <div>
                  <label class="flex items-center gap-2 text-sm font-medium text-gray-700 cursor-pointer">
                    <%= ff.check_box :faculties, {
                          multiple: true,
                          checked: Array(ff.object.faculties).include?(faculty),
                          data: { action: "change->listing-form#toggleFaculty" }
                        }, faculty, nil %>
                    <%= faculty %>
                  </label>

                  <%# Departments — hidden until faculty is checked %>
                  <div data-faculty-section="<%= faculty %>"
                       class="mt-2 ml-6 grid grid-cols-2 gap-y-1.5 gap-x-4
                              <%= Array(ff.object.faculties).include?(faculty) ? "" : "hidden" %>">
                    <p class="col-span-2 text-xs text-gray-400 mb-1">Leave unchecked to allow all departments</p>
                    <% departments.each do |dept| %>
                      <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                        <%= ff.check_box :departments, { multiple: true, checked: Array(ff.object.departments).include?(dept) }, dept, nil %>
                        <%= dept %>
                      </label>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

        <% end %>
      </div>

      <%# Submit %>
      <div class="pt-2">
        <%= form.submit "Post Listing",
              class: "w-full py-3 px-6 bg-cuhk-purple text-white font-semibold rounded-xl
                      hover:bg-cuhk-purple-dark transition-colors cursor-pointer" %>
      </div>

    <% end %>
  </div>
</div>
