<%
  status_classes = {
    "unsold"     => "bg-green-100 text-green-700 border border-green-200",
    "in_process" => "bg-amber-100 text-amber-700 border border-amber-200",
    "sold"       => "bg-gray-100 text-gray-500 border border-gray-200"
  }
  status_labels = {
    "unsold"     => "Available",
    "in_process" => "In Process",
    "sold"       => "Sold"
  }
  category_icons = {
    "furniture"     => "🪑",
    "accessories"   => "👜",
    "tech"          => "💻",
    "books"         => "📚",
    "miscellaneous" => "📦"
  }
%>
<% content_for :title, "CUrousell — #{@listing.title}" %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <%= link_to home_path,
        class: "inline-flex items-center gap-1.5 text-cuhk-purple hover:text-cuhk-purple-light
                text-sm font-medium mb-6 group" do %>
    <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none"
         stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to listings
  <% end %>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2">

      <%# Images %>
      <div class="bg-gray-50 flex flex-col items-center justify-center min-h-72 md:min-h-96"
           data-controller="listing-gallery">
        <% if @listing.images.attached? %>
          <%= image_tag @listing.images.first.variant(resize_to_limit: [600, 600]),
                class: "max-h-96 w-full object-contain",
                alt: @listing.title,
                data: { listing_gallery_target: "mainImage" } %>
          <% if @listing.images.count > 1 %>
            <div class="flex gap-2 p-3 overflow-x-auto w-full">
              <% @listing.images.each_with_index do |img, i| %>
                <%= image_tag img.variant(resize_to_fill: [80, 80]),
                      class: "w-20 h-20 object-cover rounded-lg border-2 #{ i == 0 ? 'border-cuhk-gold' : 'border-gray-200' } flex-shrink-0 cursor-pointer",
                      alt: "#{@listing.title} photo #{i + 1}",
                      data: {
                        listing_gallery_target: "thumbnail",
                        action: "click->listing-gallery#show",
                        full_src: url_for(img.variant(resize_to_limit: [600, 600]))
                      } %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="text-8xl">
            <%= category_icons[@listing.category] || "📦" %>
          </div>
        <% end %>
      </div>

      <%# Details %>
      <div class="p-8 flex flex-col">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="text-xs font-medium text-cuhk-purple border border-cuhk-purple-light
                       rounded-full px-3 py-1 capitalize">
            <%= @listing.category %>
          </span>
          <span class="text-xs font-semibold px-3 py-1 rounded-full
                       <%= status_classes[@listing.status] %>">
            <%= status_labels[@listing.status] %>
          </span>
          <% if @listing.restricted? %>
            <span class="text-xs font-medium px-3 py-1 rounded-full
                         bg-cuhk-purple text-cuhk-gold border border-cuhk-gold">
              Members Only
            </span>
          <% end %>
        </div>

        <h1 class="text-2xl font-bold text-gray-900 mb-3 leading-snug">
          <%= @listing.title %>
        </h1>

        <div class="flex items-baseline gap-3 mb-5">
          <% if @listing.price.zero? %>
            <p class="text-3xl font-bold text-green-600">Free</p>
          <% else %>
            <p class="text-3xl font-bold text-cuhk-gold">
              HK$<%= number_with_precision(@listing.price, precision: 0, delimiter: ",") %>
            </p>
          <% end %>
          <% if @listing.negotiable? %>
            <span class="text-xs font-medium text-cuhk-purple border border-cuhk-purple-light rounded-full px-2 py-0.5">
              Negotiable
            </span>
          <% end %>
        </div>

        <% if @listing.description.present? %>
          <div class="text-gray-600 text-sm leading-relaxed mb-6 flex-1">
            <%= simple_format @listing.description %>
          </div>
        <% end %>

        <% if @listing.restricted? %>
          <div class="border-t border-gray-100 pt-5 space-y-2">
            <p class="text-xs font-semibold text-cuhk-purple uppercase tracking-wide">Availability</p>
            <% @listing.access_rules.each_with_index do |rule, i| %>
              <% parts = [] %>
              <% parts << "Colleges: #{rule.colleges.join(", ")}"       if rule.colleges.any? %>
              <% parts << "Faculties: #{rule.faculties.join(", ")}"     if rule.faculties.any? %>
              <% parts << "Departments: #{rule.departments.join(", ")}" if rule.departments.any? %>
              <div class="text-xs text-gray-500">
                <% if i > 0 %>
                  <span class="font-semibold text-cuhk-gold">or</span>
                <% end %>
                <%= parts.join(" · ") %>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="space-y-2 text-sm text-gray-500 border-t border-gray-100 pt-5">
          <% if @listing.location.present? %>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-cuhk-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span><%= @listing.location %></span>
            </div>
            <div class="rounded-xl overflow-hidden border border-gray-100 mt-2">
              <% map_q = @listing.latitude.present? && @listing.longitude.present? \
                           ? "#{@listing.latitude},#{@listing.longitude}" \
                           : CGI.escape("#{@listing.location}, Hong Kong") %>
              <iframe
                width="100%"
                height="220"
                style="border:0"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
                src="https://www.google.com/maps/embed/v1/place?key=<%= Rails.application.credentials.google_maps_api_key %>&q=<%= map_q %>">
              </iframe>
            </div>
          <% end %>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-cuhk-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Listed <%= time_ago_in_words(@listing.created_at) %> ago</span>
          </div>
        </div>

        <div class="mt-5 p-4 bg-gray-50 rounded-xl border border-gray-100 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-cuhk-purple flex items-center justify-center
                      text-cuhk-gold font-bold text-lg flex-shrink-0">
            <%= @listing.user.name&.first&.upcase || "?" %>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium">Seller</p>
            <p class="text-sm font-semibold text-gray-800"><%= @listing.user.name %></p>
            <% if @listing.user.college.present? %>
              <p class="text-xs text-cuhk-purple-light"><%= @listing.user.college %></p>
            <% end %>
          </div>
        </div>

        <% if current_user == @listing.user %>
          <div class="mt-5 block text-center bg-gray-100 text-gray-400 font-semibold py-3 rounded-xl cursor-not-allowed">
            This is your listing
          </div>
        <% elsif @listing.status == "unsold" %>
          <% if @listing.price.positive? %>
            <%= button_to payment_checkout_path(listing_id: @listing.id),
                  method: :post,
                  form: { data: { turbo: false } },
                  class: "mt-5 w-full text-center bg-cuhk-gold text-cuhk-purple font-semibold py-3 rounded-xl
                          hover:brightness-105 transition-all cursor-pointer" do %>
              Buy Now &middot; HK$<%= number_with_precision(@listing.price, precision: 0, delimiter: ",") %>
            <% end %>
          <% end %>
          <%= link_to new_chat_path(listing_id: @listing.id),
                class: "mt-3 block text-center border border-cuhk-purple text-cuhk-purple font-semibold py-3 rounded-xl
                        hover:bg-cuhk-purple hover:text-white transition-colors" do %>
            Chat with Seller
          <% end %>
        <% else %>
          <div class="mt-5 block text-center bg-gray-100 text-gray-400 font-semibold py-3 rounded-xl cursor-not-allowed">
            <%= @listing.status == "sold" ? "This item has been sold" : "Transaction in progress" %>
          </div>
        <% end %>

      </div>
    </div>
  </div>

</div>
