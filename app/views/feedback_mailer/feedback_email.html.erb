<div style="font-family: Inter, sans-serif; max-width: 600px; margin: 0 auto; color: #1A1A2E;">
  <div style="background: #4E2A84; padding: 24px 32px;">
    <h1 style="margin: 0; color: white; font-size: 22px; font-weight: 700;">
      <span style="color: #C9A84C;">CU</span>rousell — Feedback
    </h1>
  </div>

  <div style="padding: 32px; background: #FAF8F5; border: 1px solid #E8D5A3;">
    <p style="margin: 0 0 8px 0; font-size: 13px; color: #6B3FA0; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">
      From
    </p>
    <p style="margin: 0 0 24px 0; font-size: 15px;">
      <%= @sender_email %>
    </p>

    <p style="margin: 0 0 8px 0; font-size: 13px; color: #6B3FA0; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">
      Message
    </p>
    <p style="margin: 0; font-size: 15px; white-space: pre-wrap; line-height: 1.6;">
      <%= @message %>
    </p>
  </div>

  <div style="padding: 16px 32px; background: #4E2A84; text-align: center;">
    <p style="margin: 0; font-size: 12px; color: rgba(255,255,255,0.4);">
      CUrousell · CSCI3100 Project · CUHK
    </p>
  </div>
</div>
