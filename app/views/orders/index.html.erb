<div class="max-w-4xl mx-auto p-6" data-controller="orders">
  <h1 class="text-3xl font-bold mb-6">My Orders</h1>

  <!-- Tabs for Bought/Sold -->
  <div class="flex border-b border-gray-200 mb-6">
    <button
      class="py-2 px-4 border-b-2 font-medium text-sm"
      data-orders-target="boughtTab"
      data-action="click->orders#showBought"
      data-active-class="border-blue-500 text-blue-600"
      data-inactive-class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
      Bought Items
    </button>
    <button
      class="py-2 px-4 border-b-2 font-medium text-sm ml-8"
      data-orders-target="soldTab"
      data-action="click->orders#showSold"
      data-active-class="border-blue-500 text-blue-600"
      data-inactive-class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
      Sold Items
    </button>
  </div>

  <!-- Status Filter -->
  <div class="mb-6">
    <label for="status-filter" class="block text-sm font-medium text-gray-700 mb-2">Filter by Status</label>
    <select id="status-filter" class="border border-gray-300 rounded-md px-3 py-2" data-action="change->orders#filterStatus">
      <option value="">All</option>
      <option value="pending">Pending</option>
      <option value="completed">Completed</option>
    </select>
  </div>

  <!-- Bought Orders Section -->
  <div id="bought-orders" data-orders-target="boughtSection">
    <h2 class="text-xl font-semibold mb-4">Items I've Bought</h2>
    <div class="space-y-4">
      <% @bought_orders.each do |order| %>
        <%= render partial: 'order', locals: { order: order, is_bought: true } %>
      <% end %>
    </div>
  </div>

  <!-- Sold Orders Section -->
  <div id="sold-orders" data-orders-target="soldSection" class="hidden">
    <h2 class="text-xl font-semibold mb-4">Items I've Sold</h2>
    <div class="space-y-4">
      <% @sold_orders.each do |order| %>
        <%= render partial: 'order', locals: { order: order, is_bought: false } %>
      <% end %>
    </div>
  </div>
</div>