<div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm" data-status="<%= order.status %>">
  <div class="flex items-start space-x-4">
    <!-- Listing Image -->
    <div class="flex-shrink-0">
      <% if order.listing.images.attached? %>
        <%= image_tag order.listing.images.first.variant(resize_to_limit: [100, 100]), class: "w-16 h-16 object-cover rounded-md" %>
      <% else %>
        <div class="w-16 h-16 bg-gray-200 rounded-md flex items-center justify-center">
          <span class="text-gray-400 text-xs">No Image</span>
        </div>
      <% end %>
    </div>

    <!-- Order Details -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900 truncate">
          <%= link_to order.listing.title, listing_path(order.listing), class: "hover:text-blue-600" %>
        </h3>
        <div class="flex items-center space-x-2">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= order_status_badge_class(order.status) %>">
            <%= order.status.titleize %>
          </span>
          <% if order.status == "pending" %>
            <% if local_assigns[:is_bought] && order.seller_confirmed_at.present? %>
              <%= button_to "Mark as Received", confirm_order_path(order), method: :post, class: "text-sm text-green-600 hover:text-green-800" %>
            <% elsif !local_assigns[:is_bought] %>
              <%= button_to "Mark as Delivered", confirm_order_path(order), method: :post, class: "text-sm text-green-600 hover:text-green-800" %>
            <% end %>
          <% elsif order.status == "delivered" && local_assigns[:is_bought] %>
            <%= button_to "Mark as Received", confirm_order_path(order), method: :post, class: "text-sm text-green-600 hover:text-green-800" %>
          <% end %>
          <% if !local_assigns[:is_bought] && order.status == "cancelled" %>
            <%= link_to "Edit", edit_listing_path(order.listing), class: "text-sm text-blue-600 hover:text-blue-800" %>
          <% end %>
        </div>
      </div>

      <p class="text-sm text-gray-500 mt-1">
        $<%= number_with_precision(order.price_at_purchase, precision: 2) %>
      </p>

      <div class="mt-2 text-sm text-gray-600">
        <% if local_assigns[:is_bought] %>
          <p>Seller: <%= order.seller.name %> (<%= order.seller.college %>)</p>
        <% else %>
          <p>Buyer: <%= order.buyer.name %> (<%= order.buyer.college %>)</p>
        <% end %>
      </div>

      <div class="mt-2 text-xs text-gray-500">
        <p>Purchased: <%= order.purchased_at&.strftime('%B %d, %Y at %I:%M %p') || order.created_at.strftime('%B %d, %Y at %I:%M %p') %></p>
        <% if order.completed_at %>
          <p>Completed: <%= order.completed_at.strftime('%B %d, %Y at %I:%M %p') %></p>
        <% end %>
        <% if order.status == "pending" %>
          <% expires_at = (order.purchased_at || order.created_at) + 2.weeks %>
          <p class="text-amber-600">Auto-cancels: <%= expires_at.strftime('%B %d, %Y') %></p>
        <% end %>
      </div>

      <!-- Waiting state indicators -->
      <% if order.status == "pending" %>
        <div class="mt-3">
          <% if local_assigns[:is_bought] %>
            <div class="inline-flex items-center px-3 py-2 rounded-md bg-amber-50 border border-amber-200">
              <svg class="w-4 h-4 text-amber-600 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
              <% if order.seller_confirmed_at.present? %>
                <span class="text-sm text-amber-800">Seller has confirmed delivery. Please mark as received after you get the item.</span>
              <% else %>
                <span class="text-sm text-amber-800">Waiting for seller to confirm delivery...</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% elsif order.status == "delivered" %>
        <div class="mt-3">
          <div class="inline-flex items-center px-3 py-2 rounded-md bg-blue-50 border border-blue-200">
            <svg class="w-4 h-4 text-blue-600 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
            <span class="text-sm text-blue-800">Marked as delivered — waiting for buyer to confirm receipt…</span>
          </div>
        </div>
      <% end %>

      <!-- Chat button -->
      <div class="mt-3">
        <% chat = Conversation.where(listing_id: order.listing_id)
                              .where("sender_id = ? OR receiver_id = ?", current_user.id, current_user.id)
                              .first %>
        <% if local_assigns[:is_bought] %>
          <% if chat %>
            <%= link_to "Chat with Seller", chat_path(chat), class: "inline-flex items-center px-3 py-1.5 rounded-md text-xs font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors" %>
          <% else %>
            <%= link_to "Chat with Seller", new_chat_path(listing_id: order.listing_id), class: "inline-flex items-center px-3 py-1.5 rounded-md text-xs font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors" %>
          <% end %>
        <% else %>
          <% if chat %>
            <%= link_to "Chat with Buyer", chat_path(chat), class: "inline-flex items-center px-3 py-1.5 rounded-md text-xs font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors" %>
          <% else %>
            <span class="inline-flex items-center px-3 py-1.5 rounded-md text-xs font-medium bg-gray-50 text-gray-400 border border-gray-200 cursor-not-allowed">No chat yet</span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
