<% content_for :title, "CUrousell — Chat" %>

<div class="h-[calc(100vh-4rem)] bg-gray-50 flex flex-col overflow-hidden">
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between py-4">
        <div class="flex items-center gap-3">
          <%= link_to chats_path, 
            class: "p-2 -ml-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          <% end %>
          
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-cuhk-purple flex items-center justify-center">
              <span class="text-cuhk-gold font-bold">
                <%= @other_user.name.first.upcase %>
              </span>
            </div>
            <div>
              <h2 class="font-semibold text-gray-900"><%= @other_user.name %></h2>
              <p class="text-xs text-gray-500"><%= @conversation.listing.title %></p>
            </div>
          </div>
        </div>

        <%= link_to listing_path(@conversation.listing_id), 
          class: "text-cuhk-purple hover:text-cuhk-purple-dark text-sm font-medium" do %>
          View Listing →
        <% end %>
      </div>
    </div>
  </div>

  <%# Messages Container %>
  <div class="flex-1 overflow-y-auto" id="messages-container" data-conversation-id="<%= @conversation.id %>">
    <div id="messages-list" class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <% @messages.each do |message| %>
          <% is_own = message.user == current_user %>
          <div id="message-<%= message.id %>" class="flex <%= is_own ? 'justify-end' : 'justify-start' %> mb-4">
            <div class="max-w-[75%] <%= is_own ? 'bg-cuhk-purple text-white' : 'bg-white text-gray-900 border border-gray-200' %> rounded-2xl px-4 py-3 shadow-sm">
              <% unless is_own %>
                <span class="text-xs font-semibold text-cuhk-purple mb-1 block"><%= message.user.name %></span>
              <% end %>
              <p class="text-sm"><%= message.content %></p>
              <span class="text-xs <%= is_own ? 'text-white/70' : 'text-gray-400' %> mt-1 block"><%= message.created_at.strftime("%H:%M") %></span>
            </div>
          </div>
        <% end %>
    </div>
  </div>

  <%# Message Input %>
  <div class="bg-white border-t border-gray-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center gap-3">
        <div class="flex-1 relative">
          <input type="text" 
                 id="message-input" 
                 placeholder="Type a message..." 
                 autocomplete="off"
                 class="w-full px-4 py-3 bg-gray-100 border-0 rounded-full focus:ring-2 focus:ring-cuhk-purple focus:bg-white transition-colors">
        </div>
        <button type="button" id="send-button"
          class="p-3 bg-cuhk-purple text-white rounded-full hover:bg-cuhk-purple-dark transition-colors shadow-md">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script type="module">
  import { createConsumer } from "@rails/actioncable"

  // Create consumer - cookies are sent automatically for authentication
  const consumer = createConsumer("/cable");

  const conversationId = <%= @conversation.id %>;
  
  // Create Action Cable subscription
  const chat = consumer.subscriptions.create({ channel: "ChatChannel", conversation_id: conversationId }, {
    connected() {
      console.log("Connected to chat channel", conversationId);
    },
    disconnected() {
      console.log("Disconnected from chat channel");
    },
    received(data) {
      console.log("Received:", data);
      const scrollContainer = document.getElementById('messages-container');
      const messagesList = document.getElementById('messages-list');
      const input = document.getElementById('message-input');
      const currentUserId = <%= current_user.id %>;

      if (messagesList) {
        // Check if message already exists to prevent duplicates
        if (document.getElementById(`message-${data.id}`)) {
          console.log("Message already exists, skipping duplicate");
          return;
        }

        // Create message HTML with unique ID for deduplication
        const isOwn = data.user_id == currentUserId;
        const messageHtml = `
          <div id="message-${data.id}" class="flex ${isOwn ? 'justify-end' : 'justify-start'} mb-4">
            <div class="max-w-[75%] ${isOwn ? 'bg-cuhk-purple text-white' : 'bg-white text-gray-900 border border-gray-200'} rounded-2xl px-4 py-3 shadow-sm">
              ${!isOwn ? `<span class="text-xs font-semibold text-cuhk-purple mb-1 block">${data.user_name}</span>` : ''}
              <p class="text-sm">${escapeHtml(data.content)}</p>
              <span class="text-xs ${isOwn ? 'text-white/70' : 'text-gray-400'} mt-1 block">${data.created_at}</span>
            </div>
          </div>
        `;

        messagesList.insertAdjacentHTML('beforeend', messageHtml);
        scrollContainer.scrollTop = scrollContainer.scrollHeight;

        // Clear input only if it's our own message
        if (isOwn && input) {
          input.value = '';
        }
      }
    },
    speak(message) {
      return this.perform('speak', { message: message });
    }
  });
  
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Send message by clicking the button 
  document.getElementById('send-button')?.addEventListener('click', function() {
    const input = document.getElementById('message-input');
    const message = input?.value.trim();
    if (message) {
      chat.speak(message);
    }
  });

  // Send message by enter 
  document.getElementById('message-input')?.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      const message = this.value.trim();
      if (message) {
        chat.speak(message);
      }
    }
  });
</script>
