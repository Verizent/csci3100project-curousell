<% content_for :title, "CUrousell — Contact Seller" %>

<div class="max-w-2xl mx-auto px-4 py-10">
  <%= link_to listing_path(@listing),
        class: "inline-flex items-center gap-1.5 text-cuhk-purple hover:text-cuhk-purple-light
                text-sm font-medium mb-6 group" do %>
    <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none"
         stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to item
  <% end %>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h1 class="text-xl font-bold text-gray-900 mb-2">Contact Seller</h1>
    
    <%# Listing summary %>
    <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl mb-6">
      <% if @listing.images.attached? %>
        <%= image_tag @listing.images.first.variant(resize_to_fill: [80, 80]),
              class: "w-16 h-16 object-cover rounded-lg",
              alt: @listing.title %>
      <% else %>
        <div class="w-16 h-16 bg-gray-200 rounded-lg flex items-center justify-center text-2xl">
          📦
        </div>
      <% end %>
      <div>
        <p class="font-semibold text-gray-800"><%= @listing.title %></p>
        <p class="text-sm text-gray-500">
          <%= @listing.user.name %> · <%= @listing.price.zero? ? "Free" : "HK$#{@listing.price}" %>
        </p>
      </div>
    </div>

    <%= form_with url: send_message_chat_path(@listing.id),
          method: :post,
          class: "space-y-4" do |f| %>
      <%= hidden_field_tag :listing_id, @listing.id %>

      <div>
        <label for="message_content" class="block text-sm font-medium text-gray-700 mb-2">
          What do you want to ask from a seller?
        </label>
        <textarea
          id="message_content"
          name="message_content"
          rows="5"
          required
          placeholder="Hi! Is this one still available?"
          class="w-full px-4 py-3 rounded-xl border-2 border-gray-200
                 focus:outline-none focus:border-cuhk-gold text-gray-800
                 placeholder-gray-400 text-sm resize-none"
        ></textarea>
      </div>

      <div class="flex gap-3">
        <%= f.submit "Send Message",
              class: "flex-1 bg-cuhk-purple text-white font-semibold py-3 rounded-xl
                     hover:bg-cuhk-purple-dark transition-colors cursor-pointer" %>
        <%= link_to "Cancel",
              listing_path(@listing),
              class: "px-6 py-3 border-2 border-gray-200 text-gray-600 font-semibold rounded-xl
                     hover:border-gray-300 transition-colors text-center" %>
      </div>
    <% end %>
  </div>
</div>