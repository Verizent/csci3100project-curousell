<% content_for :title, "CUrousell — Messages" %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%# Header %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Messages</h1>
    <p class="text-gray-500 text-sm mt-1">Your conversation history</p>
  </div>

  <%# Conversations List %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <% if @conversations.any? %>
      <div class="divide-y divide-gray-100">
        <% @conversations.each do |conversation| %>
          <% other_user = conversation.other_participant(current_user) %>
          <%= link_to chat_path(conversation), class: "block p-4 hover:bg-gray-50 transition-colors" do %>
            <div class="flex items-start gap-4">
              <%# Avatar %>
              <div class="flex-shrink-0">
                <div class="w-12 h-12 rounded-full bg-cuhk-purple flex items-center justify-center">
                  <span class="text-cuhk-gold font-bold">
                    <%= other_user.name.first.upcase %>
                  </span>
                </div>
              </div>

              <%# Content %>
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between mb-1">
                  <h3 class="font-semibold text-gray-900 truncate">
                    <%= other_user.name %>
                  </h3>
                  <% if conversation.last_message %>
                    <span class="text-xs text-gray-400">
                      <%= time_ago_in_words(conversation.last_message.created_at) %> ago
                    </span>
                  <% end %>
                </div>
                
                <p class="text-sm text-cuhk-purple truncate mb-1">
                  <%= conversation.listing.title %>
                </p>
                
                <% if conversation.last_message %>
                  <p class="text-sm text-gray-500 truncate">
                    <% if conversation.last_message.user == current_user %>
                      <span class="text-gray-400">You:</span>
                    <% end %>
                    <%= conversation.last_message.content %>
                  </p>
                <% else %>
                  <p class="text-sm text-gray-400 italic">No messages yet</p>
                <% end %>
              </div>

              <%# Listing Thumbnail %>
              <div class="flex-shrink-0">
                <div class="w-12 h-12 rounded-lg bg-cuhk-purple/10 flex items-center justify-center">
                  <span class="text-xl">💬</span>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%# Empty State %>
      <div class="p-8 text-center">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-cuhk-purple/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-cuhk-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Empty Chat History</h3>
        <p class="text-gray-500 mb-4">Let's wait until you find something you like ...or dislike</p>
        <%= link_to "Browse Listings", listings_path, 
          class: "inline-flex items-center px-4 py-2 bg-cuhk-purple text-white rounded-lg hover:bg-cuhk-purple-dark transition-colors" %>
      </div>
    <% end %>
  </div>
</div>