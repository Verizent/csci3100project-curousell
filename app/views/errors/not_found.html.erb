<% content_for :title, "Page Not Found — CUrousell" %>

<div class="max-w-lg mx-auto px-4 py-24 text-center">
  <p class="text-8xl font-bold text-cuhk-purple opacity-20 leading-none mb-6">404</p>
  <h1 class="text-2xl font-bold text-gray-900 mb-3">Page not found</h1>
  <p class="text-gray-500 mb-8">
    The page you're looking for doesn't exist or has been moved.
  </p>
  <%= link_to home_path, class: "inline-block bg-cuhk-purple text-white font-semibold px-8 py-3 rounded-xl hover:bg-cuhk-purple-dark transition-colors" do %>
    Go to Home
  <% end %>
</div>
