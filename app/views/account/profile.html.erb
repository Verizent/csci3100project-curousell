<div class="max-w-2xl mx-auto px-4 py-12">
  <div class="bg-white rounded-xl shadow-lg overflow-hidden">

    <%# Header %>
    <div class="bg-cuhk-purple px-6 py-8 flex items-center gap-5">
      <div class="w-16 h-16 rounded-full bg-cuhk-gold flex items-center justify-center text-2xl font-bold text-white shrink-0">
        <%= @user.name.first.upcase %>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-white"><%= @user.name %></h1>
        <p class="text-cuhk-gold-light text-sm mt-0.5"><%= @user.email %></p>
      </div>
    </div>

    <%# Info rows %>
    <div class="divide-y divide-gray-100 px-6">

      <div class="py-4 flex gap-4">
        <span class="w-36 shrink-0 text-sm font-medium text-gray-500">College</span>
        <span class="text-sm text-gray-900"><%= @user.college %></span>
      </div>

      <div class="py-4 flex gap-4">
        <span class="w-36 shrink-0 text-sm font-medium text-gray-500">Faculty</span>
        <div class="flex flex-wrap gap-1.5">
          <% Array(@user.faculty).each do |f| %>
            <span class="inline-block bg-indigo-50 text-indigo-700 text-xs font-medium px-2.5 py-1 rounded-full"><%= f %></span>
          <% end %>
        </div>
      </div>

      <div class="py-4 flex gap-4">
        <span class="w-36 shrink-0 text-sm font-medium text-gray-500">Department</span>
        <div class="flex flex-wrap gap-1.5">
          <% Array(@user.department).each do |d| %>
            <span class="inline-block bg-purple-50 text-purple-700 text-xs font-medium px-2.5 py-1 rounded-full"><%= d %></span>
          <% end %>
        </div>
      </div>

      <div class="py-4 flex gap-4">
        <span class="w-36 shrink-0 text-sm font-medium text-gray-500">Member since</span>
        <span class="text-sm text-gray-900"><%= @user.created_at.strftime("%-d %B %Y") %></span>
      </div>

    </div>

    <%# Sign out %>
    <div class="px-6 pb-6 pt-2">
      <%= button_to "Sign Out", account_signout_path, method: :delete,
            class: "w-full py-2.5 text-sm font-semibold text-white bg-red-500 hover:bg-red-600 rounded-lg transition" %>
    </div>

  </div>
</div>
